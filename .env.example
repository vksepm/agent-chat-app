# Environment variables for the AI Assistant application.
# Copy this file to .env and fill in the values.
# NEVER commit .env to source control.

# ---------------------------------------------------------------------------
# Model provider configuration (required)
# ---------------------------------------------------------------------------
# Model type to use: hf_api, litellm (default), openai_server, azure_openai_server
MODEL_TYPE=litellm

# Model ID/name (required for all types):
# - hf_api: e.g. "Qwen/Qwen2.5-Coder-32B-Instruct"
# - litellm: e.g. "openai/gpt-4o", "anthropic/claude-3-5-sonnet-20241022"
# - openai_server: e.g. "gpt-4o"
# - azure_openai_server: e.g. deployment name like "gpt-4o-mini"
MODEL_ID=

# API key (required for litellm, openai_server, azure_openai_server; not for hf_api)
MODEL_API_KEY=

# ---------------------------------------------------------------------------
# Model-specific configuration (required only for specific MODEL_TYPE values)
# ---------------------------------------------------------------------------

# For hf_api: HuggingFace API token (optional if using huggingface_hub default auth)
# HF_TOKEN=

# For openai_server: API base URL (optional; defaults to https://api.openai.com/v1)
# OPENAI_API_BASE=https://api.openai.com/v1

# For azure_openai_server: Azure endpoint URL (required for azure_openai_server)
# AZURE_ENDPOINT=

# For azure_openai_server: API version (required for azure_openai_server)
# AZURE_API_VERSION=2024-12-01-preview

# ---------------------------------------------------------------------------
# MCP servers (both required)
# ---------------------------------------------------------------------------
# HTTP Streamable MCP server base URLs — must be HTTPS
MCP_SERVER_URL_1=
MCP_SERVER_URL_2=

# ---------------------------------------------------------------------------
# Langfuse telemetry (required for P2+ tracing)
# ---------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Langfuse host — defaults to https://cloud.langfuse.com if omitted
LANGFUSE_HOST=

# Optional: explicit project ID for Langfuse deep-link URLs in the UI.
# Langfuse v3 derives the project from the public key, but setting this
# enables direct per-trace URL generation in the metadata panel (SC-006).
LANGFUSE_PROJECT_ID=

# ---------------------------------------------------------------------------
# Application metadata (optional)
# ---------------------------------------------------------------------------
# Version tag injected into Langfuse trace metadata. Defaults to "dev".
APP_VERSION=

# Agent verbosity level (optional; defaults to 1 = INFO):
#   -1 = OFF:   Minimal/no logging
#    0 = ERROR: Only errors are logged
#    1 = INFO:  Standard logging (default)
#    2 = DEBUG: Very verbose, logs all steps and decisions
AGENT_VERBOSITY_LEVEL=1

# Agent max steps (optional; defaults to 5):
# Maximum number of steps the agent can take to solve a task.
# Each step consists of one thought and one tool call. Set this to limit agent iterations.
AGENT_MAX_STEPS=5

# ---------------------------------------------------------------------------
# Data logging (all optional — degrades gracefully when unset)
# ---------------------------------------------------------------------------
# Local directory for the interaction log file (interactions.jsonl).
# Defaults to "logs/" relative to the project root.
DATA_LOG_DIR=logs

# HuggingFace Hub dataset repo ID to sync logs to, e.g. "username/chat-logs".
# If unset, local logging still works but no HF Hub sync occurs.
HF_DATASET_REPO_ID=

# HuggingFace write token (required when HF_DATASET_REPO_ID is set).
# Create at https://huggingface.co/settings/tokens with "write" scope.
# HF_TOKEN=

# How often (seconds) to push the local log file to HF Hub. Default: 300 (5 min).
HF_SYNC_INTERVAL=300

