# Environment variables for the AI Assistant application.
# Copy this file to .env and fill in the values.
# NEVER commit .env to source control.

# ---------------------------------------------------------------------------
# Model provider (required)
# ---------------------------------------------------------------------------
# LiteLLM model ID, e.g. "openai/gpt-4o", "anthropic/claude-3-5-sonnet-20241022"
MODEL_ID=

# API key for the model provider
MODEL_API_KEY=

# ---------------------------------------------------------------------------
# MCP servers (both required)
# ---------------------------------------------------------------------------
# HTTP Streamable MCP server base URLs — must be HTTPS
MCP_SERVER_URL_1=
MCP_SERVER_URL_2=

# ---------------------------------------------------------------------------
# Langfuse telemetry (required for P2+ tracing)
# ---------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Langfuse host — defaults to https://cloud.langfuse.com if omitted
LANGFUSE_HOST=

# Optional: explicit project ID for Langfuse deep-link URLs in the UI.
# Langfuse v3 derives the project from the public key, but setting this
# enables direct per-trace URL generation in the metadata panel (SC-006).
LANGFUSE_PROJECT_ID=

# ---------------------------------------------------------------------------
# Application metadata (optional)
# ---------------------------------------------------------------------------
# Version tag injected into Langfuse trace metadata. Defaults to "dev".
APP_VERSION=
